<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:titleTextColor="@android:color/white"
            app:navigationIconTint="@android:color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Date range chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/primary"
            android:contentDescription="Date range"/>

        <TextView
            android:id="@+id/tvDateRange"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Status message -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:textSize="13sp"
        android:textColor="@color/on_surface_variant"/>

    <!-- SIGN-IN GROUP (shown when not signed in) -->
    <LinearLayout
        android:id="@+id/groupSignIn"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="G"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:background="@color/primary"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect your Google account to automatically find boarding passes, cab receipts, hotel invoices and food bills in Gmail during your business trip dates."
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign in with Google"
            app:backgroundTint="@color/primary"
            app:icon="@drawable/ic_settings"
            app:iconSize="18dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Only read access is used. Emails are never stored or sent anywhere."
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant"
            android:textAlignment="center"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

    <!-- MAIN CONTENT GROUP (shown when signed in) -->
    <LinearLayout
        android:id="@+id/groupContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Fetch + Select All buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFetchEmails"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Fetch Emails"
                android:textSize="12sp"
                android:maxLines="1"
                app:backgroundTint="@color/primary"
                app:icon="@drawable/ic_save"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Deselect All"
                android:textSize="11sp"
                android:maxLines="1"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>

        <!-- Email list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEmails"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImportSelected"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Scan Selected Emails"
            android:textSize="13sp"
            android:maxLines="1"
            android:enabled="false"
            app:backgroundTint="@color/primary"
            app:icon="@drawable/ic_camera"
            app:iconSize="16dp"
            app:iconPadding="6dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

</LinearLayout>
