<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/primary" app:titleTextColor="@android:color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- AI Provider Selection -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="AI Provider for Receipt Scanning"
                android:textStyle="bold" android:textColor="@color/primary"
                android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <RadioGroup android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <RadioButton android:id="@+id/radioGroq"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Groq  (FREE – LLaMA Vision, fast)" android:textSize="14sp"/>
                <RadioButton android:id="@+id/radioGemini"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Google Gemini  (FREE – gemini-1.5-flash)" android:textSize="14sp"/>
                <RadioButton android:id="@+id/radioOllama"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Ollama  (Local on PC – no key needed)" android:textSize="14sp"/>
                <RadioButton android:id="@+id/radioClaude"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Claude  (Paid – most accurate)" android:textSize="14sp"/>
            </RadioGroup>

            <!-- Groq / Gemini / Claude: API Key -->
            <LinearLayout android:id="@+id/layoutClaude"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:id="@+id/tvApiKeyHint"
                    android:text="API Key"
                    android:textSize="12sp" android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="API Key" android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:endIconMode="password_toggle">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etApiKey" android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" android:fontFamily="monospace"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Ollama: endpoint + model -->
            <LinearLayout android:id="@+id/layoutOllama"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Enter your PC's local IP where Ollama is running.\nRun: ollama serve  on your PC first."
                    android:textSize="12sp" android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Ollama URL (e.g. http://192.168.1.5:11434)"
                    android:layout_marginBottom="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etOllamaEndpoint" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="textUri"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Model name (e.g. llava:latest, kimi-k2:latest)"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etOllamaModel" android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Employee defaults -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Default Employee Details (pre-filled on new trips)"
                android:textStyle="bold" android:textColor="@color/primary"
                android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Employee Name" android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDefaultEmployee" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Employee ID" android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDefaultEmployeeId" android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Department" android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDefaultDept" android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Designation" android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDefaultDesignation" android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Cost Center" android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDefaultCostCenter" android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Save Settings"
                app:backgroundTint="@color/primary"/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
